APP_ENV=development
API_PORT=8000
FRONTEND_PORT=5173

# Project URL (required for ES256/RS256 user tokens via JWKS …/auth/v1/.well-known/jwks.json)
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Optional: only for legacy HS256 session tokens. New “JWT signing keys” (ECC/RSA) need SUPABASE_URL only.
SUPABASE_JWT_SECRET=

# Model paths default to the repository ``models/`` directory (absolute paths resolved in app.config).
# From ``backend/``, that is ``../models/``. Uncomment only to override:
# MODEL_DIR=
# BEHAVIORAL_MODEL_PATH=
# BEHAVIORAL_AE_PATH=
# GRAPH_MODEL_PATH=
# ENTITY_MODEL_PATH=
# TEMPORAL_MODEL_PATH=
# OFFRAMP_MODEL_PATH=
# META_MODEL_PATH=
# THRESHOLD_POLICY_PATH=

FALLBACK_RISK_THRESHOLD=0.75
NETWORK_HOPS=3

# ML: set true to use GPU when available (CUDA for XGBoost+PyTorch; PyTorch may use Apple MPS if no CUDA)
ML_USE_GPU=false
